generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppRole {
  ADMIN
  PROJECT_MANAGER
  USER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum RecordType {
  CREDENTIAL
  SECURE_NOTE
}

enum RecordSensitivity {
  STANDARD
  SENSITIVE
}

enum AuditAction {
  LOGIN
  FAILED_LOGIN
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_DELETED
  RECORD_CREATED
  RECORD_UPDATED
  RECORD_DELETED
  SECRET_REVEALED
  SECRET_COPIED
  ROLE_CHANGED
  RESTRICTION_CHANGED
  SHARE_CREATED
  SHARE_REVEALED
  SHARE_EXPIRED
  DATA_EXPORTED
  CLIENT_ARCHIVED
  CLIENT_RESTORED
  RECORD_ARCHIVED
  RECORD_RESTORED
}

model Category {
  id         String           @id @default(cuid())
  name       String
  slug       String           @unique
  isDefault  Boolean          @default(false)
  order      Int              @default(0)
  ownerId    String?
  owner      User?            @relation("PersonalCategories", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  projects   Project[]
  userAccess CategoryAccess[]

  @@index([ownerId])
}

model CategoryAccess {
  id         String   @id @default(cuid())
  categoryId String
  userId     String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([categoryId, userId])
  @@index([userId])
  @@index([categoryId])
}

model User {
  id             String           @id @default(cuid())
  clerkUserId    String?          @unique
  email          String?          @unique
  firstName      String?
  lastName       String?
  role           AppRole          @default(USER)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  auditEvents        AuditEvent[]
  categoryAccess     CategoryAccess[]
  personalCategories Category[]       @relation("PersonalCategories")
  sharedBundles      SharedBundle[]
}

model Project {
  id           String         @id @default(cuid())
  name         String
  contact      String?
  vertical     String?
  notes        String?
  status       ClientStatus   @default(ACTIVE)
  categoryId   String?
  category     Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isRestricted Boolean        @default(false)
  archivedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  records      Record[]
  tags         Tag[]          @relation("ClientTags")
  auditEvents  AuditEvent[]
  sharedBundles SharedBundle[]

  @@index([categoryId])
  @@map("Client")
}

model Record {
  id           String            @id @default(cuid())
  projectId    String            @map("clientId")
  title        String
  type         RecordType
  serviceName  String?
  url          String?
  username     String?
  secretCipher String?
  notes        String?
  sensitivity  RecordSensitivity @default(SENSITIVE)
  isRestricted Boolean           @default(false)
  hasHistory   Boolean           @default(false)
  archivedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  createdById  String?
  updatedById  String?
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tags         Tag[]             @relation("RecordTags")
  auditEvents  AuditEvent[]

  @@index([projectId], map: "Record_clientId_idx")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  projects  Project[] @relation("ClientTags")
  records   Record[]  @relation("RecordTags")
}

model AuditEvent {
  id         String      @id @default(cuid())
  action     AuditAction
  resource   String
  resourceId String
  metadata   Json?
  createdAt  DateTime    @default(now())
  actorId    String?
  projectId  String?     @map("clientId")
  recordId   String?
  actor      User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  record     Record?     @relation(fields: [recordId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([resource, resourceId])
  @@index([actorId])
  @@index([projectId], map: "AuditEvent_clientId_idx")
  @@index([recordId])
}

model SharedBundle {
  id              String    @id @default(cuid())
  createdById     String
  projectId       String
  recordIds       String[]
  clientEmail     String?
  otpHash         String?
  otpExpiresAt    DateTime?
  otpSentAt       DateTime?
  otpAttempts     Int       @default(0)
  otpLockedUntil  DateTime?
  expiresAt       DateTime?
  expiredManually Boolean   @default(false)
  createdAt       DateTime  @default(now())

  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([projectId])
}

model AppSettings {
  id               String  @id @default("singleton")
  sharingFromEmail String?
  sharingFromName  String?
}

model SystemLog {
  id        String   @id @default(cuid())
  source    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}
